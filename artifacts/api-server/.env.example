DATABASE_URL=postgres://user:password@localhost:5432/aura

# Solana / Minting
SOLANA_TREASURY_SECRET_KEY=
SOLANA_DEVNET_RPC_URL=

# OpenAI (image transform)
OPENAI_API_KEY=

# Rate limiting (production only — omit or leave blank to use defaults)
# POST /api/aura/card — max requests per IP per hour
RATE_LIMIT_CARD_PER_HOUR=5
# POST /api/aura/transform — max requests per IP per 15 minutes
RATE_LIMIT_TRANSFORM_PER_15MIN=10
# POST /api/aura/mint — max requests per IP per hour
RATE_LIMIT_MINT_PER_HOUR=3
