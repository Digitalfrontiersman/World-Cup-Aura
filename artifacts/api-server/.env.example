# --- Required ---
DATABASE_URL=postgres://user:password@localhost:5432/aura
# Local dev port (Replit injects this in prod). The frontend dev proxy targets 5000.
PORT=5000

# --- OpenAI (image transform) ---
# A plain OpenAI key works — it's bridged onto the integration's expected vars.
OPENAI_API_KEY=
# Optional: override the OpenAI-compatible base URL (defaults to https://api.openai.com/v1)
# OPENAI_BASE_URL=
# Replit's managed OpenAI integration sets these directly instead of OPENAI_API_KEY:
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# --- Solana / Minting ---
# Prefer the gitignored artifacts/api-server/.solana-treasury.json file for the
# secret; set these only if you can't use a file. NEVER commit a private key.
SOLANA_TREASURY_SECRET_KEY=
SOLANA_DEVNET_RPC_URL=

# --- CORS ---
# Comma-separated allow-list of origins permitted to call the API in production,
# e.g. https://worldcupaura.com. When unset, any localhost origin is allowed (dev).
CORS_ALLOWED_ORIGINS=

# --- Rate limiting ---
# Rate limiting is ON by default (fail-closed). Set to true to disable locally.
RATE_LIMIT_DISABLED=false
# Tunable limits (per IP). Omit to use defaults.
# POST /api/aura/card — per hour
RATE_LIMIT_CARD_PER_HOUR=5
# POST /api/aura/transform — per 15 minutes
RATE_LIMIT_TRANSFORM_PER_15MIN=10
# POST /api/aura/mint — per hour
RATE_LIMIT_MINT_PER_HOUR=3
# PATCH /api/aura/card/:slug/image — per hour
RATE_LIMIT_IMAGE_PER_HOUR=30
# POST vote/comment — per 15 minutes
RATE_LIMIT_COMMUNITY_PER_15MIN=60
