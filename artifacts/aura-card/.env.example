# ─────────────────────────────────────────────────────────────────────────────
# Frontend (aura-card) environment — copy this file to `.env` and fill in values.
#
#   cp artifacts/aura-card/.env.example artifacts/aura-card/.env
#
# ONLY vars prefixed with VITE_ are exposed to the browser. Never put a real
# secret here — anything in a VITE_ var ships to every visitor's browser.
# The real `.env` is gitignored; this template is the only tracked env file.
# ─────────────────────────────────────────────────────────────────────────────

# Canonical app URL, used for share links / OG tags.
# Falls back to window.location.origin if unset.
VITE_APP_URL=https://worldcupaura.com

# Solana devnet RPC endpoint used by the in-browser wallet (mint/balance reads).
# Accepts a full RPC URL or a bare Helius API key. If unset, falls back to the
# rate-limited public devnet endpoint.
VITE_SOLANA_DEVNET_RPC_URL=

# --- Analytics (all optional; leave blank to disable that provider) ---
# GA4 Measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=
# Facebook Pixel ID, e.g. 1234567890
VITE_FB_PIXEL_ID=
# PostHog project API key (Project Settings → API Keys). Enables recordings/funnels.
VITE_POSTHOG_API_KEY=
# PostHog ingest host (optional). Defaults to https://us.i.posthog.com.
# Use https://eu.i.posthog.com for EU residency, or your self-hosted URL.
VITE_POSTHOG_HOST=

# --- Local dev only ---
# Where the dev server proxies /api requests. Defaults to http://localhost:5000
# (the local api-server). Override if your API runs elsewhere.
VITE_API_PROXY_TARGET=
