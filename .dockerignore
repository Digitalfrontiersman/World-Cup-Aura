# Keep the Docker build context small and secret-free.
# Anything here is NOT sent to the builder.

# Dependencies / build outputs are regenerated inside the image.
**/node_modules
**/dist
**/.vite
**/*.tsbuildinfo

# Secrets must never enter an image layer.
**/.env
**/.env.*
**/.solana-treasury.json

# VCS / editor / CI noise.
.git
.github
**/.DS_Store

# Docs and local-only files not needed to build the server.
*.md
**/*.md
.replit
.replitignore
